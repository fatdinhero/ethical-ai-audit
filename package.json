{\n  "name": "@ideaip/ethical-ai-audit",\n  "version": "1.0.0",\n  "description": "Automated ethical compliance audits for AI systems - GDPR, AI Act, ISO 42001 ready",\n  "main": "dist/core/index.js",\n  "types": "dist/core/index.d.ts",\n  "bin": {\n    "ethical-audit": "dist/cli/index.js"\n  },\n  "exports": {\n    ".": {\n      "import": "./dist/core/index.mjs",\n      "require": "./dist/core/index.js",\n      "types": "./dist/core/index.d.ts"\n    },\n    "./premium": {\n      "import": "./dist/premium/index.mjs",\n      "require": "./dist/premium/index.js",\n      "types": "./dist/premium/index.d.ts"\n    }\n  },\n  "files": ["dist", "README.md", "SECURITY.md", "SBOM.json"],\n  "scripts": {\n    "build": "tsc",\n    "build:premium": "tsc --project tsconfig.premium.json",\n    "build:all": "npm run build && npm run build:premium",\n    "test": "jest",\n    "lint": "eslint src --ext .ts",\n    "typecheck": "tsc --noEmit"\n  },\n  "keywords": ["ethical-ai", "ai-audit", "compliance", "gdpr", "ai-act", "iso-42001"],\n  "author": "fatdinhero",\n  "license": "MIT",\n  "repository": {\n    "type": "git",\n    "url": "https://github.com/fatdinhero/ethical-ai-audit.git"\n  },\n  "engines": {\n    "node": ">=18.0.0",\n    "npm": ">=9.0.0"\n  },\n  "dependencies": {\n    "axios": "^1.6.0",\n    "dotenv": "^16.3.1"\n  },\n  "devDependencies": {\n    "@types/jest": "^29.5.8",\n    "@types/node": "^20.10.0",\n    "typescript": "^5.3.3",\n    "jest": "^29.7.0",\n    "ts-jest": "^29.1.1"\n  },\n  "publishConfig": {\n    "access": "public"\n  }\n}